# Ephemeral worker artifacts — everything under tasks/ is per-run state.
/tasks/*
!/tasks/.gitkeep
/logs/

# Example batch outputs (regenerated on every run)
/examples/*/output/
/examples/**/*.log
/examples/**/*.summary
/examples/**/*.exitcode
/examples/**/*.status

# Editor / OS
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Local-only overrides
.env
.env.local
*.local

# Claude Code local state
.claude/
